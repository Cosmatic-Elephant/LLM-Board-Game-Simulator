# Copy this file to .env.local and fill in your API keys

# LLM Provider API Keys (add whichever you plan to use)
ANTHROPIC_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GOOGLE_API_KEY=your_key_here

# Model to use per LLM player slot (optional — defaults set in lib/llm-client.ts)
LLM_PLAYER_1_MODEL=claude-sonnet-4-6
LLM_PLAYER_2_MODEL=gpt-4o
LLM_PLAYER_3_MODEL=gemini-2.5-flash
LLM_PLAYER_4_MODEL=claude-sonnet-4-6
